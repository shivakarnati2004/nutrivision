# ============================================
# NutriVision — Environment Variables Template
# ============================================
# Copy this file to server/.env and fill in your values
# NEVER commit the actual .env file

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL — Use EITHER DATABASE_URL or individual vars
# DATABASE_URL=postgresql://user:password@host:5432/nutrivision
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=nutrivision

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Email (SMTP) — Gmail example
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_FROM=your_email@gmail.com

# OTP Settings
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

# JWT
JWT_SECRET=change_this_to_a_strong_random_secret

# CORS (comma-separated origins, or * for all)
# CORS_ORIGIN=https://your-frontend.onrender.com
